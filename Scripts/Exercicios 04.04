# 3 - Propor o else para o script abaixo:
#O else é uma estrutura condicional que define o que deve acontecer quando a condição do if não é verdadeira. 
#Ele permite criar um "desvio" no fluxo do código: se a condição for TRUE, executa o bloco do if; se for FALSE, executa o bloco do else.

# Inicia o loop para cada pacote 
required_packages <- c("dplyr", "ggplot2", "tidyr")

# Verifica se o pacote existe
for (pkg in required_packages) {
  if (!require(pkg, character.only = TRUE)) {

# se o pacote não existe, istala 
    cat(paste("Pacote", pkg, "não encontrado. Instalando...\n"))
    install.packages(pkg, dependencies = TRUE)
 #Carrega o pacote    
    library(pkg, character.only = TRUE)
    cat(paste("Pacote", pkg, "instalado e carregado com sucesso!\n"))
  } else {
  # se o pacote existe,apenas carrega
    
    cat(paste("Pacote", pkg, "já está carregado. Pulando instalação.\n"))
  }
}


# 4 - Refatorar o script (Criar pasta no google drive) de forma tal que o CRUD que funcione de forma modular

#Instale o pacote (rode apenas uma vez):

install.packages("googledrive")
# Carregar o pacote googledrive
library(googledrive)

# MÓDULO 1: Autenticação no Google Drive
autenticar_drive <- function() {
  # Verifica se já está autenticado, se não, abre navegador para login
  drive_auth()
  message("✅ Autenticado com sucesso!")
}

# MÓDULO 2: Verificar se pasta existe
verificar_pasta <- function(nome_pasta, caminho_pai = NULL) {
  # Busca pasta com o nome especificado
  # Se caminho_pai for NULL, procura na raiz
  pasta <- drive_find(
    type = "folder",  # Apenas pastas
    pattern = nome_pasta,  # Nome da pasta
    q = ifelse(is.null(caminho_pai), 
               "trashed = false",  # Não deletadas
               paste0("'", caminho_pai, "' in parents"))  # Na pasta pai
  )
  
  # Retorna TRUE se encontrou, FALSE se não
  return(nrow(pasta) > 0)
}

# MÓDULO 3: Criar pasta no Google Drive
criar_pasta <- function(nome_pasta, caminho_pai = NULL, sobrescrever = FALSE) {
  
  # Verifica se a pasta já existe
  existe <- verificar_pasta(nome_pasta, caminho_pai)
  
  # Se existe e não pode sobrescrever, retorna erro
  if (existe && !sobrescrever) {
    stop(paste("❌ Pasta '", nome_pasta, "' já existe! Use sobrescrever = TRUE para recriar"))
  }
  
  # Se existe e pode sobrescrever, deleta a antiga
  if (existe && sobrescrever) {
    message(paste("⚠️ Deletando pasta existente:", nome_pasta))
    drive_rm(paste0(nome_pasta, "/"))  # Remove pasta existente
  }
  
  # Cria a nova pasta
  nova_pasta <- drive_mkdir(nome_pasta, path = caminho_pai)
  
  message(paste("✅ Pasta criada com sucesso:", nome_pasta))
  
  # Retorna informações da pasta criada
  return(nova_pasta)
}

# MÓDULO 4: Função principal que integra tudo
criar_pasta_google <- function(nome_pasta, 
                               caminho_pai = NULL, 
                               autenticar = TRUE,
                               sobrescrever = FALSE) {
  
  # Etapa 1: Autenticação 
  if (autenticar) {
    autenticar_drive()
  }
  
  # Etapa 2: Criar pasta
  resultado <- criar_pasta(nome_pasta, caminho_pai, sobrescrever)
  
  # Etapa 3: Mostrar link da pasta
  cat(paste("\n🔗 Link da pasta:", resultado$drive_resource[[1]]$webViewLink, "\n"))
  
  return(resultado)
}


