# 1 - Criar script que confira para que pasta o projeto está apontando e,
# caso a pasta não exista, crie a pasta; e caso, a pasta já exista configure para a pasta de trabalho correta.

# Verifica se a pasta "meu_projeto" existe no diretório atual

if (!dir.exists("meu_projeto")) {
  # Se não existir, cria a pasta
  dir.create("meu_projeto")
  print("Pasta criada com sucesso!")
} else {
  # Se já existir, apenas informa
  print("Pasta já existe.")
}

# Configura a pasta de trabalho para a pasta "meu_projeto"
setwd("meu_projeto")

# Confirma o diretório de trabalho atual
print(paste("Diretório de trabalho atual:", getwd()))



